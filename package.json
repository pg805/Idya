{
  "//1": "describes your app and its dependencies",
  "//2": "https://docs.npmjs.com/files/package.json",
  "//3": "updating this file will download and update your packages",
  "name": "idya",
  "type": "module",
  "version": "0.1.5",
  "description": "RPG Bot",
  "author": "pg805",
  "main": "./src/discord/init.ts",
  "module": "./lib/discord/deploy_commands.js",
  "scripts": {
    "start": "node ./lib/server/index.js",
    "start:discord-legacy": "node ./lib/discord/init.js",
    "refresh-commands": "node ./lib/discord/deploy-commands.js",
    "cli-test": "node ./lib/test_battle.js",
    "build": "tsc --project tsconfig.json",
    "lint": "eslint . --fix",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "simulate": "npm run build && node ./lib/tools/simulate.js",
    "sim:save": "npm run build && node -e \"const v=require('./package.json').version; require('child_process').execSync('node ./lib/tools/simulate.js --json docs/sim/'+v+'.json',{stdio:'inherit'})\"",
    "price:smoke": "npm run build && node ./lib/tools/price_smoke.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "discord.js": "^14.18.0",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "js-yaml": "^4.1.1",
    "node-fetch": "^2.6.1",
    "node-schedule": "^1.3.2",
    "prisma": "^5.22.0",
    "sequelize": "^6.37.5",
    "socket.io": "^4.8.3",
    "sqlite3": "^5.1.7",
    "winston": "^3.17.0"
  },
  "engines": {
    "node": ">=16.6.0"
  },
  "repository": {
    "url": "git+https://github.com/pg805/Idya.git"
  },
  "license": "MIT",
  "keywords": [
    "node",
    "express"
  ],
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.1",
    "@typescript-eslint/eslint-plugin": "^4.14.1",
    "@typescript-eslint/parser": "^4.14.1",
    "cross-env": "^10.1.0",
    "eslint": "^7.32.0",
    "eslint-config-google": "^0.14.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.9",
    "typescript": "^5.2.2"
  },
  "bugs": {
    "url": "https://github.com/pg805/idya/issues"
  },
  "homepage": "https://github.com/pg805/idya#readme"
}
