generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  discord_id         String      @id
  korel              Int         @default(0)
  tutorial_complete  Boolean     @default(false)
  created_at         DateTime    @default(now())
  characters         Character[]
}

model Character {
  id           String          @id @default(uuid())
  discord_id   String
  name         String
  sprite_token String?
  health       Int
  max_health   Int
  weapon_key   String

  user         User            @relation(fields: [discord_id], references: [discord_id])
  inventory    InventoryItem[]
  weapons      CharacterWeapon[]
}

model Item {
  id          String          @id
  name        String
  description String
  inventory   InventoryItem[]
}

model CharacterWeapon {
  character_id  String
  weapon_key    String

  character     Character @relation(fields: [character_id], references: [id])

  @@id([character_id, weapon_key])
}

model KorelLedger {
  id         String   @id @default(uuid())
  discord_id String
  amount     Int
  reason     String
  note       String?
  created_at DateTime @default(now())
}

model BattleLog {
  id           String   @id @default(uuid())
  discord_id   String
  character_id String
  enemy        String
  outcome      String
  korel_delta  Int
  loot         String?
  started_at   DateTime
  ended_at     DateTime @default(now())
}

model EventLog {
  id         String   @id @default(uuid())
  discord_id String
  event_type String
  payload    Json?
  created_at DateTime @default(now())
}

model ShopTransaction {
  id         String   @id @default(uuid())
  shop_id    String
  item_id    String
  type       String   // 'buy' | 'sell'
  quantity   Int
  discord_id String
  created_at DateTime @default(now())
}

model InventoryItem {
  character_id  String
  item_id       String
  quantity      Int       @default(1)

  character     Character @relation(fields: [character_id], references: [id])
  item          Item      @relation(fields: [item_id], references: [id])

  @@id([character_id, item_id])
}
