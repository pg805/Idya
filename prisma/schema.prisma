generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  discord_id         String      @id
  korel              Int         @default(0)
  tutorial_complete  Boolean     @default(false)
  created_at         DateTime    @default(now())
  // When true, Discord announcements that name the player use a <@id> ping
  // instead of the bare character name. Default false (quieter for most).
  ping_on_action     Boolean     @default(false)
  characters         Character[]
}

model Character {
  id                  String   @id @default(uuid())
  discord_id          String
  name                String
  sprite_token        String?
  nationality         String?
  faction             String   @default("neutral")   // empire | town | neutral; set at creation, gates NPC dialogue
  bio                 String?
  health              Int
  max_health          Int
  equipped_weapon_id  String?

  user                User                  @relation(fields: [discord_id], references: [discord_id])
  equipped_weapon     CharacterWeapon?      @relation("EquippedWeapon", fields: [equipped_weapon_id], references: [id])
  inventory           InventoryItem[]
  weapons             CharacterWeapon[]     @relation("OwnedWeapons")
  professions         CharacterProfession[]
  orchard_plots       OrchardPlot[]
  npc_relations       PlayerNpcRelation[]
}

// Player <-> NPC relationship. opinion (warmth, 0-10) and familiarity are the
// stored axes; `standing` (the friendship tier) is DERIVED at read time, not
// stored. shared_history holds dialogue flags. One row per (character, npc).
model PlayerNpcRelation {
  character_id   String
  npc_id         String
  met_before     Boolean   @default(false)
  familiarity    Int       @default(0)
  opinion        Int       @default(5)
  shared_history Json      @default("[]")
  last_spoken_at DateTime?
  updated_at     DateTime  @updatedAt

  character      Character @relation(fields: [character_id], references: [id])

  @@id([character_id, npc_id])
}

model CharacterProfession {
  character_id  String
  profession    String
  level         Int       @default(0)

  character     Character @relation(fields: [character_id], references: [id])

  @@id([character_id, profession])
}

model Item {
  id          String          @id
  name        String
  description String
  inventory   InventoryItem[]
}

// Lumberjack orchard: a plot multiplies a planted item over 4h ticks (capped at
// 24h / 6 ticks). The seed is spent on plant; harvest banks the rolled output.
// `accrued` is the banked output so far; rolls are persisted so the page matches
// harvest. An idle plot has item_id = null. One row per (character, slot).
model OrchardPlot {
  character_id  String
  slot          Int
  item_id       String?
  seed_count    Int       @default(0)
  fertilizer    Int       @default(0)   // allocated from a pool = plot count; modifies odds
  accrued       Int       @default(0)
  ticks_banked  Int       @default(0)   // rolls since plant; capped at 6
  last_tick_at  DateTime  @default(now())

  character     Character @relation(fields: [character_id], references: [id])

  @@id([character_id, slot])
}

model CharacterWeapon {
  id            String     @id @default(uuid())
  character_id  String
  weapon_key    String
  upgrades      Json       @default("{}")
  created_at    DateTime   @default(now())

  character     Character  @relation("OwnedWeapons", fields: [character_id], references: [id])
  equipped_by   Character[] @relation("EquippedWeapon")

  @@index([character_id, weapon_key])
}

model KorelLedger {
  id         String   @id @default(uuid())
  discord_id String
  amount     Int
  reason     String
  note       String?
  created_at DateTime @default(now())
}

model BattleLog {
  id           String          @id @default(uuid())
  discord_id   String
  character_id String
  enemy        String
  outcome      String
  korel_delta  Int
  loot         String?
  started_at   DateTime
  ended_at     DateTime        @default(now())
  // Filterable on the dev stats page. NULL on pre-0.2.0 rows.
  version      String?
  weapon_key   String?
  // Player upgrade count on the equipped weapon at battle time (each = +1; 3 = a
  // weapon level). Lets the stats page split a weapon by effective level. NULL on
  // rows logged before this was tracked.
  weapon_upgrades Int?
  // Per-battle metrics for the dev stats page. NULL on pre-0.2.0 rows.
  // Multi-enemy battles emit one row per enemy; player-side metrics
  // (player_hp_left, damage_received, rounds_count, crit_count,
  // aimed_attempted, aimed_hit, restores, player_went_first) repeat
  // across rows. Enemy-side metrics (damage_dealt, enemy_hp_left) are
  // per-enemy.
  player_hp_left     Int?
  enemy_hp_left      Int?
  damage_dealt       Int?
  damage_received    Int?
  rounds_count       Int?
  crit_count         Int?
  aimed_attempted    Int?
  aimed_hit          Int?
  restores           Int?
  player_went_first  Boolean?
  rounds             BattleRoundLog?
}

model BattleRoundLog {
  id        String   @id @default(uuid())
  battle_id String   @unique
  battle    BattleLog @relation(fields: [battle_id], references: [id])
  rounds    Json
}

model EventLog {
  id         String   @id @default(uuid())
  discord_id String
  event_type String
  payload    Json?
  created_at DateTime @default(now())
}

model ShopItemState {
  shop_id           String
  item_id           String
  x                 Float    @default(0.5)
  stock             Int      @default(0)
  cumulative_volume BigInt   @default(0)
  recent_volume     BigInt   @default(0)
  last_tick         DateTime @default(now())

  @@id([shop_id, item_id])
}

model ShopTransaction {
  id         String   @id @default(uuid())
  shop_id    String
  item_id    String
  type       String   // 'buy' | 'sell'
  quantity   Int
  discord_id String
  created_at DateTime @default(now())
}

// Tick-level price-state history — one snapshot per item per hour (the demand
// state x + stock). Enough to reconstruct the sell/buy price at any past tick
// and graph the real market the same way the sim does. Pruned to ~30 days.
model ShopPriceTick {
  id      String   @id @default(uuid())
  shop_id String
  item_id String
  at      DateTime @default(now())
  x       Float
  stock   Int

  @@index([shop_id, item_id, at])
}

model InventoryItem {
  character_id  String
  item_id       String
  quantity      Int       @default(1)

  character     Character @relation(fields: [character_id], references: [id])
  item          Item      @relation(fields: [item_id], references: [id])

  @@id([character_id, item_id])
}

// Global timed quest: players deposit an item toward a shared target for a fixed
// price; participants earn a rank-tiered trophy when it completes. Authored as a
// YAML in database/quests/ and materialized into a row when its start time hits.
model GlobalQuest {
  id          String         @id
  name        String
  lore        String
  item_id     String
  target      Int
  price       Int            // korel paid per item deposited (fixed for the quest)
  deposited   Int            @default(0)
  starts_at   DateTime
  ends_at     DateTime
  status      String         @default("scheduled") // scheduled | active | completed
  created_at  DateTime       @default(now())
  deposits    QuestDeposit[]
}

model QuestDeposit {
  id            String      @id @default(uuid())
  quest_id      String
  character_id  String
  quantity      Int         @default(0)
  rank          Int?        // frozen 1/2/3/… at completion; null while active
  created_at    DateTime    @default(now())
  updated_at    DateTime    @updatedAt

  quest         GlobalQuest @relation(fields: [quest_id], references: [id])

  @@unique([quest_id, character_id])
  @@index([character_id])
}
